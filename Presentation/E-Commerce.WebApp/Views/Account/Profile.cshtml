@using E_CommerceApplication.Dtos.AccountDtos
@model ResultProfileDto

<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-12">

            <!-- TABS -->
            <div class="nav nav-tabs justify-content-center border-secondary mb-4">
                <a class="nav-item nav-link active" data-toggle="tab" href="#tab-pane-1">Bilgiler</a>
                <a class="nav-item nav-link" data-toggle="tab" href="#tab-pane-2">Siparişler</a>
                <a class="nav-item nav-link" data-toggle="tab" href="#tab-pane-3">Şifreyi Değiştir</a>
            </div>

            <div class="tab-content">

                <!-- PROFİL BİLGİLERİ -->
                <div class="tab-pane fade show active" id="tab-pane-1">
                    <div class="card border-secondary mb-5">
                        <div class="card-header bg-secondary border-0">
                            <h4 class="font-weight-semi-bold m-0">Profil Bilgileri</h4>
                        </div>
                        <div class="card-body">
                            <form action="/Account/Profile" method="post">
                                <div class="row">

                                    <div class="col-md-6 form-group">
                                        <label>Ad</label>
                                        <input type="text" name="name" value="@Model.Name" class="form-control" />
                                    </div>

                                    <div class="col-md-6 form-group">
                                        <label>Soyad</label>
                                        <input type="text" name="surname" value="@Model.Surname" class="form-control" />
                                    </div>

                                    <div class="col-md-6 form-group">
                                        <label>Email</label>
                                        <input type="text" value="@Model.Email" class="form-control" readonly />
                                    </div>

                                    <div class="col-md-6 form-group">
                                        <label>Telefon</label>
                                        <input type="text" value="@Model.PhoneNumber" class="form-control" readonly />
                                    </div>

                                </div>

                                <button type="submit" class="btn btn-primary px-4 mt-3">
                                    Kaydet
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- SİPARİŞLER -->
                <div class="tab-pane fade" id="tab-pane-2">
                    <div class="card border-secondary mb-5">
                        <div class="card-header bg-secondary border-0">
                            <h4 class="font-weight-semi-bold m-0">Siparişlerim</h4>
                        </div>
                        <div class="card-body table-responsive">
                            <table class="table table-bordered text-center mb-0">
                                <thead class="bg-secondary text-dark">
                                    <tr>
                                        <th>Tarih</th>
                                        <th>Durum</th>
                                        <th>Toplam</th>
                                        <th>Ürünler</th>
                                        <th>Fatura</th>
                                    </tr>
                                </thead>
                                <tbody class="align-middle">
                                    @if (Model.Orders != null && Model.Orders.Any())
                                    {
                                        foreach (var item in Model.Orders)
                                        {
                                            <tr>
                                                <td>@item.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                                <td>@item.OrderStatus</td>
                                                <td>@item.TotalAmount ₺</td>
                                                <td>
                                                    @foreach (var orderitem in item.OrderItems)
                                                    {
                                                        <span class="badge badge-light">
                                                            @orderitem.Product.ProductName
                                                        </span>
                                                    }
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-primary">
                                                        <i class="fa fa-file"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="5">Sipariş bulunamadı</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ŞİFRE DEĞİŞTİR -->
                <div class="tab-pane fade" id="tab-pane-3">
                    <div class="card border-secondary mb-5">
                        <div class="card-header bg-secondary border-0">
                            <h4 class="font-weight-semi-bold m-0">Şifre Değiştir</h4>
                        </div>
                        <div class="card-body">
                            <form action="/Account/ChangePassword" method="post">

                                <div class="form-group">
                                    <label>Mevcut Şifre</label>
                                    <input type="password" name="password" class="form-control" required />
                                </div>

                                <div class="form-group">
                                    <label>Yeni Şifre</label>
                                    <input type="password" name="newpassword" class="form-control" required />
                                </div>

                                <div class="form-group">
                                    <label>Yeni Şifre (Tekrar)</label>
                                    <input type="password" name="confirmnewpassword" class="form-control" required />
                                </div>

                                <button type="submit" class="btn btn-danger px-4 mt-3">
                                    Şifreyi Güncelle
                                </button>

                            </form>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>
